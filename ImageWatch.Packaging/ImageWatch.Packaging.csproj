  <Target Name="RemoveLocalizationMarkers" AfterTargets="Localize">
    <PropertyGroup>
      <PowerShellExe>$(SystemRoot)\System32\WindowsPowerShell\v1.0\powershell.exe</PowerShellExe>
      <RemoveXmlScript>$(MSBuildThisFileDirectory)..\Remove-XmlNodes.ps1</RemoveXmlScript>
      <LocalizationMarkers>_locDefinition</LocalizationMarkers>
    </PropertyGroup>
    <ItemGroup>
      <FilesWithMarkers Include="$(OutDir)localize\**\%(Language.Identity)\LocalizeNatVis\*.natvis" />
    </ItemGroup>
    <Exec Condition=" '@(FilesWithMarkers)' != '' " Command="$(PowerShellExe) -NonInteractive -ExecutionPolicy Unrestricted -File $(RemoveXmlScript) -Files @(FilesWithMarkers) -Nodes $(LocalizationMarkers) -DestinationPath $(OutDir)localizeProcessed -NumPathComponents 3" />
  </Target>
  <Target Name="AddLocalizedItems" BeforeTargets="GetVsixSourceItems">
    <ItemGroup>
      <VSIXSourceItem Include="$(OutDir)localize\**\%(Language.Identity)\extension.vsixlangpack">
        <VSIXSubPath>%(Language.Culture)</VSIXSubPath>
      </VSIXSourceItem>
      <VSIXSourceItem Include="$(OutDir)localizeProcessed\**\%(Language.Identity)\LocalizeNatVis\*.natvis">
        <VSIXSubPath>%(Language.LCID)</VSIXSubPath>
      </VSIXSourceItem>
    </ItemGroup>
  </Target>
